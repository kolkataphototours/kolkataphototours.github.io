<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --ink:#1a1612;--warm-white:#f5f0e8;--paper:#ede8de;
    --amber:#c47a2a;--amber-light:#e8a84a;--muted:#7a7060;
    --border:rgba(26,22,18,0.12);
    --serif:'Cormorant Garamond',Georgia,serif;
    --mono:'DM Mono',monospace;--sans:'Barlow',sans-serif
  }
  body{background:var(--warm-white);color:var(--ink);font-family:var(--sans);font-weight:300;line-height:1.8}

  /* ── HEADER ── */
  .site-header{display:flex;justify-content:space-between;align-items:center;padding:1.5rem 3rem;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--warm-white);z-index:100}
  .logo{font-family:var(--mono);font-size:.75rem;letter-spacing:.18em;text-transform:uppercase;color:var(--ink);text-decoration:none}
  nav a{font-family:var(--mono);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);text-decoration:none;margin-left:2rem;transition:color .2s}
  nav a:hover{color:var(--ink)} nav a.active{color:var(--amber)}

  /* ── HERO ── */
  .hero{
    padding:6rem 3rem 5.5rem;
    border-bottom:1px solid var(--border);
    max-width:1100px;margin:0 auto;
    display:grid;grid-template-columns:1fr 1fr;
    gap:6rem;align-items:center
  }
  .eyebrow{font-family:var(--mono);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--amber);margin-bottom:1.5rem;display:flex;align-items:center;gap:.8rem}
  .eyebrow::after{content:'';width:40px;height:1px;background:var(--amber);opacity:.5}
  .hero h1{font-family:var(--serif);font-size:clamp(3rem,5vw,4.8rem);font-weight:300;line-height:1.05;margin-bottom:1.2rem}
  .hero h1 em{font-style:italic;color:var(--amber)}
  .hero-desc{font-size:1rem;font-weight:300;line-height:1.9;color:#3a3530;max-width:44ch;margin-bottom:0}

  /* hero right — 3 stacked horizontal rows */
  .hero-grid{display:grid;grid-template-columns:1fr;gap:3px}
  .hg-cell{background:#ccc8be;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;aspect-ratio:3/2}
  .hg-cell img{width:100%;height:100%;object-fit:cover;display:block;filter:brightness(.85);transition:filter .3s}
  .hg-cell:hover img{filter:brightness(.95)}
  .hg-tall{grid-row:span 1}
  .hg-hint{position:absolute;font-family:var(--mono);font-size:.52rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(26,22,18,.35);text-align:center;line-height:1.8;padding:0 .8rem}
  .hg-cap{position:absolute;bottom:0;left:0;right:0;padding:7px 10px;background:linear-gradient(transparent,rgba(26,22,18,.55));font-family:var(--mono);font-size:.52rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,240,232,.7)}

  /* ── SERVICES — 3 full-width cards ── */
  .services{max-width:1100px;margin:0 auto}

  .service-card{
    display:grid;
    grid-template-columns:480px 1fr;
    gap:0;
    border-bottom:1px solid var(--border);
    text-decoration:none;
    color:inherit;
    transition:background .2s
  }
  .service-card:first-child{border-top:1px solid var(--border)}
  .service-card:hover{background:var(--paper)}
  .service-card.dark{background:var(--ink);color:var(--warm-white)}
  .service-card.dark:hover{background:#221e18}

  /* alternate photo left/right */
  .service-card:nth-child(even){grid-template-columns:1fr 480px}
  .service-card:nth-child(even) .sc-photo{order:2}
  .service-card:nth-child(even) .sc-body{order:1}

  .sc-photo{
    position:relative;overflow:hidden;
    aspect-ratio:3/2;
    background:#ccc8be;
    display:flex;align-items:center;justify-content:center
  }
  .sc-photo img{width:100%;height:100%;object-fit:cover;display:block;filter:brightness(.85);transition:filter .3s,transform .5s}
  .service-card:hover .sc-photo img{filter:brightness(.95);transform:scale(1.02)}
  .sc-photo-hint{position:absolute;font-family:var(--mono);font-size:.56rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(26,22,18,.35);text-align:center;line-height:1.8;padding:0 1.5rem}
  .sc-photo-hint-light{color:rgba(245,240,232,.3)}

  /* number watermark */
  .sc-num{
    position:absolute;top:1.5rem;left:1.5rem;
    font-family:var(--serif);font-size:4rem;font-weight:300;
    color:rgba(245,240,232,.12);line-height:1;
    pointer-events:none;user-select:none
  }

  .sc-body{
    padding:4rem 4rem;
    display:flex;flex-direction:column;justify-content:center;
    border-left:1px solid var(--border)
  }
  .service-card:nth-child(even) .sc-body{border-left:none;border-right:1px solid var(--border)}
  .service-card.dark .sc-body{border-color:rgba(255,255,255,.08)}
  .service-card.dark:nth-child(even) .sc-body{border-color:rgba(255,255,255,.08)}

  .sc-tag{font-family:var(--mono);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;color:var(--amber);margin-bottom:1.2rem;display:flex;align-items:center;gap:.7rem}
  .sc-tag::after{content:'';width:30px;height:1px;background:var(--amber);opacity:.5}
  .sc-tag-light{color:var(--amber-light)}
  .sc-tag-light::after{background:var(--amber-light)}

  .sc-title{font-family:var(--serif);font-size:clamp(2rem,3vw,2.8rem);font-weight:300;line-height:1.15;margin-bottom:1.4rem}
  .sc-title em{font-style:italic;color:var(--amber)}
  .sc-title-light em{color:var(--amber-light)}

  .sc-desc{font-size:.95rem;font-weight:300;line-height:1.88;margin-bottom:2rem}
  .sc-desc-dark{color:rgba(245,240,232,.7)}

  /* bullet points */
  .sc-bullets{display:flex;flex-direction:column;gap:0;border:1px solid var(--border);margin-bottom:2rem}
  .sc-bullet{display:flex;gap:.9rem;align-items:flex-start;padding:.85rem 1.2rem;border-bottom:1px solid var(--border);font-size:.85rem;font-weight:300;color:var(--muted);line-height:1.6}
  .sc-bullet:last-child{border-bottom:none}
  .sc-bullet-dot{width:4px;height:4px;background:var(--amber);border-radius:50%;flex-shrink:0;margin-top:8px}
  .sc-bullets-dark{border-color:rgba(255,255,255,.08)}
  .sc-bullet-dark{border-bottom-color:rgba(255,255,255,.07);color:rgba(245,240,232,.55)}

  .sc-cta{
    display:inline-flex;align-items:center;gap:.6rem;
    font-family:var(--mono);font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;
    text-decoration:none;padding:.9rem 2rem;
    background:var(--ink);color:var(--warm-white);
    transition:background .2s;align-self:flex-start
  }
  .sc-cta:hover{background:var(--amber)}
  .sc-cta svg{width:14px;height:14px;transition:transform .2s}
  .sc-cta:hover svg{transform:translateX(3px)}
  .sc-cta-light{background:var(--amber);color:var(--ink)}
  .sc-cta-light:hover{background:var(--amber-light)}
  .sc-cta-outline{background:transparent;border:1px solid rgba(245,240,232,.25);color:rgba(245,240,232,.8)}
  .sc-cta-outline:hover{background:rgba(255,255,255,.08);border-color:rgba(245,240,232,.5);color:var(--warm-white)}

  /* ── WHAT CONNECTS THEM ── */
  .connector{
    background:var(--paper);
    padding:5rem 3rem;
    border-bottom:1px solid var(--border)
  }
  .connector-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
  .conn-label{font-family:var(--mono);font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;color:var(--amber);margin-bottom:1rem;display:flex;align-items:center;gap:.8rem}
  .conn-label::after{content:'';flex:1;max-width:60px;height:1px;background:var(--amber);opacity:.4}
  .conn-heading{font-family:var(--serif);font-size:clamp(2rem,3.5vw,2.8rem);font-weight:300;line-height:1.2;margin-bottom:1.5rem}
  .conn-heading em{font-style:italic;color:var(--amber)}
  .conn-body{font-size:1rem;font-weight:300;line-height:1.9;color:#3a3530}
  .conn-stats{display:flex;flex-direction:column;gap:0;border:1px solid var(--border)}
  .conn-stat{display:flex;align-items:baseline;gap:1.5rem;padding:1.4rem 2rem;border-bottom:1px solid var(--border)}
  .conn-stat:last-child{border-bottom:none}
  .conn-num{font-family:var(--serif);font-size:2.4rem;font-weight:300;color:var(--amber);line-height:1;min-width:80px;flex-shrink:0}
  .conn-stat-text{font-size:.9rem;font-weight:300;color:var(--muted);line-height:1.5}
  .conn-stat-text strong{display:block;font-weight:400;color:var(--ink);margin-bottom:.1rem}

  /* ── QUICK QUOTE ── */
  .quick-quote{
    background:var(--ink);
    padding:4.5rem 3rem;
    border-bottom:1px solid rgba(255,255,255,.06)
  }
  .qq-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr;gap:5rem;align-items:center}
  .qq-text{font-family:var(--serif);font-size:1.6rem;font-style:italic;font-weight:300;color:rgba(245,240,232,.85);line-height:1.55;padding-left:2rem;border-left:2px solid var(--amber)}
  .qq-author{}
  .qq-name{font-size:.9rem;font-weight:400;color:var(--warm-white);margin-bottom:.25rem}
  .qq-origin{font-family:var(--mono);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(245,240,232,.3)}

  /* ── CTA ── */
  .cta-section{
    text-align:center;padding:7rem 3rem;
    background:var(--warm-white)
  }
  .cta-h{font-family:var(--serif);font-size:clamp(2.5rem,5vw,4rem);font-weight:300;line-height:1.12;margin-bottom:1.2rem}
  .cta-h em{font-style:italic;color:var(--amber)}
  .cta-sub{font-size:1rem;color:var(--muted);max-width:48ch;margin:0 auto 2.5rem;line-height:1.7}
  .cta-btns{display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap}
  .btn-dark{display:inline-block;background:var(--ink);color:var(--warm-white);font-family:var(--mono);font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;padding:.9rem 2rem;transition:background .2s}
  .btn-dark:hover{background:var(--amber)}
  .btn-ghost{display:inline-block;color:var(--muted);font-family:var(--mono);font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;padding:.9rem 0;border-bottom:1px solid var(--muted);transition:color .2s}
  .btn-ghost:hover{color:var(--ink);border-color:var(--ink)}

  /* ── FOOTER ── */
  footer{background:var(--ink);color:rgba(245,240,232,.5);padding:2rem 3rem;display:flex;justify-content:space-between;align-items:center;font-family:var(--mono);font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;border-top:1px solid rgba(255,255,255,.06)}
  footer a{color:inherit;text-decoration:none} footer a:hover{color:var(--amber-light)}

  /* ── LEGEND ── */
  .legend{background:#fdf8ef;border:1px solid rgba(196,122,42,.2);padding:2rem 3rem}
  .legend-inner{max-width:1100px;margin:0 auto}
  .legend-h{font-family:var(--mono);font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--amber);margin-bottom:1.2rem;padding-bottom:.8rem;border-bottom:1px solid rgba(196,122,42,.2)}
  .legend-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem 3rem}
  .legend-item{display:flex;gap:10px;align-items:flex-start}
  .legend-dot{width:6px;height:6px;background:rgba(196,122,42,.4);border-radius:50%;flex-shrink:0;margin-top:5px}
  .legend-text{font-family:var(--sans);font-size:.82rem;font-weight:300;color:var(--muted);line-height:1.6}

  @media(max-width:900px){
    .hero{grid-template-columns:1fr;gap:3rem;padding:3rem 1.5rem}
    .service-card,.service-card:nth-child(even){grid-template-columns:1fr}
    .sc-photo{min-height:260px;order:1 !important}
    .sc-body{order:2 !important;padding:2.5rem 1.5rem;border-left:none !important;border-right:none !important;border-top:1px solid var(--border)}
    .service-card.dark .sc-body{border-top-color:rgba(255,255,255,.08)}
    .connector-inner,.qq-inner{grid-template-columns:1fr;gap:3rem}
    .cta-section{padding:4rem 1.5rem}
    .site-header,footer,.connector,.quick-quote,.cta-section{padding-left:1.5rem;padding-right:1.5rem}
    .legend-grid{grid-template-columns:1fr}
  }
</style>
</head>
